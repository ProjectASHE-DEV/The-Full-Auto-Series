using System.Reflection;
using SPTarkov.DI.Annotations;
using SPTarkov.Server.Core.DI;
using SPTarkov.Server.Core.Models.Spt.Mod;
using SPTarkov.Server.Core.Models.Utils;
using SPTarkov.Server.Core.Services;
using System.Collections.Generic;
using System.Threading.Tasks;
using Range = SemanticVersioning.Range;

namespace FullAutoSeries;
public record ModMetadata : AbstractModMetadata
{
    public override string ModGuid { get; init; } = "com.mrlahey.fullautoseries";
    public override string Name { get; init; } = "The Full Auto Series";
    public override string Author { get; init; } = "MrLahey";
    public override SemanticVersioning.Version Version { get; init; } = new("2.0.0");
    public override Range SptVersion { get; init; } = new("4.0.13");
    public override Dictionary<string, Range>? ModDependencies { get; init; } = new()
    {
        { "com.wtt.commonlib", new Range("~2.0.0") }
    };
    public override List<string>? Contributors { get; init; }
    public override List<string>? Incompatibilities { get; init; }
    public override string? Url { get; init; }
    public override bool? IsBundleMod { get; init; } = false;
    public override string License { get; init; } = "MIT";
}

[Injectable(TypePriority = OnLoadOrder.PostDBModLoader + 2)]
public class FullAutoSeriesMod(
    ISptLogger<FullAutoSeriesMod> logger,
    WTTServerCommonLib.WTTServerCommonLib wttCommon)
    : IOnLoad
{
    public async Task OnLoad()
    {
        var assembly = Assembly.GetExecutingAssembly();

        await wttCommon.CustomItemServiceExtended.CreateCustomItems(assembly);
        await wttCommon.CustomLocaleService.CreateCustomLocales(assembly);
        await wttCommon.CustomWeaponPresetService.CreateCustomWeaponPresets(assembly);
        await wttCommon.CustomAssortSchemeService.CreateCustomAssortSchemes(assembly);

        logger.Success("[Full Auto Series] Mod Loaded, Full Auto Receivers have been added.");

        await Task.CompletedTask;
    }
}
